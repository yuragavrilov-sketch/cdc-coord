# Core app
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/postgres
DEBEZIUM_CONNECT_URL=http://localhost:8083
TOPIC_PREFIX=migration
LOG_LEVEL=INFO

# Monitoring / timeouts
CDC_HEARTBEAT_TIMEOUT_SECONDS=120
CONNECTOR_START_TIMEOUT_SECONDS=60
CONNECTOR_POLL_INTERVAL_SECONDS=2
DEFAULT_CHUNK_COUNT=64

# Oracle source (for CDC)
ORACLE_SOURCE_DSN=host.docker.internal:1521/ORCLCDB
ORACLE_SOURCE_HOST=host.docker.internal
ORACLE_SOURCE_PORT=1521
ORACLE_SOURCE_SERVICE=ORCLCDB
ORACLE_SOURCE_USER=system
ORACLE_SOURCE_PASSWORD=change_me
ORACLE_SOURCE_SCHEMA=SYSTEM

# Oracle target (for static migration)
ORACLE_TARGET_DSN=host.docker.internal:1521/ORCLCDB
ORACLE_TARGET_USER=system
ORACLE_TARGET_PASSWORD=change_me
ORACLE_TARGET_SCHEMA=SYSTEM
